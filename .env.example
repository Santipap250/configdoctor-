# OBIXConfig Doctor — Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to version control

# ─── Flask & Security ───────────────────────────────────────────
# ⚡ REQUIRED: Generate a strong SECRET_KEY before deploying
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode (disable in production)
FLASK_DEBUG=0
FLASK_ENV=production

# ─── Server Configuration ───────────────────────────────────────
PORT=10000

# ─── Proxy & Network ────────────────────────────────────────────
# Set to 1 if behind reverse proxy (Render, Docker, etc.)
# This ensures X-Forwarded-For headers are trusted for rate limiting
TRUST_PROXY=1

# Set to 1 ONLY for local HTTP development (insecure!)
FORCE_INSECURE=0

# ─── Database ──────────────────────────────────────────────────
# SQLite database path (relative to project root)
DATABASE_PATH=data/community.db

# ─── Redis (Optional) ──────────────────────────────────────────
# For rate limiting with distributed setup
# Leave empty to use in-memory storage (suitable for single worker)
REDIS_URL=

# Example for local Redis:
# REDIS_URL=redis://localhost:6379/0

# Example for Redis on Render:
# REDIS_URL=redis://default:password@red-xxxxx.render.com:6379

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Features ──────────────────────────────────────────────────
# Enable/disable optional features
ENABLE_BLACKBOX_ANALYZER=1
ENABLE_RULE_ENGINE=1
ENABLE_SECRET_SAUCE=1
ENABLE_ADVANCED_ANALYSIS=1
