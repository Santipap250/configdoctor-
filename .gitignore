# OBIXConfig Doctor — .gitignore
# ────────────────────────────────────────────────────────────────

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment & secrets (NEVER commit these)
.env
.env.*
*.secret

# Logs
*.log
logs/

# OS junk
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# OSD exports (user-generated, not part of repo)
static/downloads/osd/

# Upload temp
uploads/
tmp/
