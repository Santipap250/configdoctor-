# OBIXConfig Doctor — .gitignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.venv_backup/

# ─── Environment & Secrets (NEVER commit) ──────────────────────
.env
.env.*
!.env.example
*.secret
*.pem
*.key

# ─── Logs ──────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ─── OS Junk ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
.AppleDouble
.LSOverride

# ─── Editor & IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/
.classpath

# ─── Testing & Coverage ────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.benchmarks/

# ─── OSD Exports (user-generated) ──────────────────────────────
static/downloads/osd/
static/downloads/diff_all/

# ─── Database ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
data/

# ─── Temporary & Upload Files ─────────────────────────────────
uploads/
tmp/
temp/
*.tmp
.cache/

# ─── Backup Files ─────────────────────────────────────────────
*.bak
*.backup
*.swp
*~

# ─── Node (if using frontend build tools) ──────────────────────
node_modules/
npm-debug.log
yarn-error.log
.npm

# ─── Docker ────────────────────────────────────────────────────
.dockerignore
Docker*

# ─── System ────────────────────────────────────────────────────
.env.local
.env.*.local
*.pid
.lock
